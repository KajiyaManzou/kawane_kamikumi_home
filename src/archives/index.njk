---
layout: base.njk
title: お知らせアーカイブ
---
<div class="container">
  <section class="section">
    <h2 class="section-title">過去のお知らせ</h2>
    {% set notices = collections.notices | reverse %}
    {% if notices and notices.length > 0 %}
      <ul class="card-list">
        {% for item in notices %}
          {% set notice = item %}
          {% include "notice-card.njk" %}
        {% endfor %}
      </ul>
    {% else %}
      <p>現在お知らせはありません。</p>
    {% endif %}
    <a class="archive-link" href="/">← トップページに戻る</a>
  </section>
</div>
