<li class="card">
  <p class="card-date">{{ notice.date | dateJa }}</p>
  <a class="card-title-link" href="{{ notice.url }}">{{ notice.data.title }}</a>
  {% if notice.data.pdf %}
    <a class="card-pdf-link" href="{{ notice.data.pdf }}" target="_blank" rel="noopener">PDFを見る</a>
  {% endif %}
</li>
