<li class="card">
  <p class="card-date">{{ circular.date | dateJa }}</p>
  <a class="card-title-link" href="{{ circularCardUrl or circular.url }}">{{ circular.data.title }}</a>
  {% if circular.data.pdf %}
    <a class="card-pdf-link" href="{{ circular.data.pdf }}" target="_blank" rel="noopener">PDFを見る</a>
  {% endif %}
</li>
