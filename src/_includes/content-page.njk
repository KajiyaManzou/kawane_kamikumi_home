---
layout: base.njk
---
<div class="container">
  <article class="section">
    <h2 class="section-title">{{ title }}</h2>
    <p class="card-date">{{ page.date | dateJa }}</p>
    {% if pdf %}
      <a class="card-pdf-link" href="{{ pdf }}" target="_blank" rel="noopener">PDFを見る</a>
    {% endif %}
    <div class="content-body">
      {{ content | safe }}
    </div>
    <a class="archive-link" href="javascript:history.back()">← 戻る</a>
  </article>
</div>
